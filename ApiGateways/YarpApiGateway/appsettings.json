{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp": "Information"
    }
  },
  "AllowedHosts": "*",
  "ReverseProxy": {
    "Routes": {
      "generator-character-route": {
        "ClusterId": "generator-cluster",
        "Match": {
          "Path": "/api/character/{**catch-all}"
        }
      },
      "generator-factions-route": {
        "ClusterId": "generator-cluster",
        "Match": {
          "Path": "/api/factions/{**catch-all}"
        }
      },
      "generator-races-route": {
        "ClusterId": "generator-cluster",
        "Match": {
          "Path": "/api/races/{**catch-all}"
        }
      },
      "generator-classes-route": {
        "ClusterId": "generator-cluster",
        "Match": {
          "Path": "/api/classes/{**catch-all}"
        }
      },
      "generator-professions-route": {
        "ClusterId": "generator-cluster",
        "Match": {
          "Path": "/api/professions/{**catch-all}"
        }
      },
      "character-service-route": {
        "ClusterId": "character-cluster",
        "Match": {
          "Path": "/api/characters/{**catch-all}"
        }
      }
    },
    "Clusters": {
      "generator-cluster": {
        "Destinations": {
          "generator-api-1": {
            "Address": "http://localhost:5001"
          }
        }
      },
      "character-cluster": {
        "Destinations": {
          "character-api-1": {
            "Address": "http://localhost:5002"
          }
        }
      }
    }
  }
}
