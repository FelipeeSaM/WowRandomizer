{
  "ConnectionStrings": {
    "Redis": "redis:6379"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Clusters": {
      "generator-cluster": {
        "Destinations": {
          "generator-api-1": {
            "Address": "http://wowrandomizer.api:8080"
          }
        }
      },
      "character-cluster": {
        "Destinations": {
          "character-api-1": {
            "Address": "http://wowrandomizer.character.api:8080"
          }
        }
      }
    }
  }
}